# .env.example - GUIA OFICIAL DE CONFIGURAÇÃO
# -------------------------------------------------------------------------
# IMPORTANTE: Não coloque suas senhas reais aqui. 
# Use o menu "Settings > Secrets" no painel do AI Studio para inserir estes valores.
# -------------------------------------------------------------------------

# SUPABASE (Obrigatório para o Banco de Dados)
VITE_SUPABASE_URL=https://sua-url.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# FACILITA MÓVEL (Obrigatório para envio de SMS)
FACILITA_USER=seu-usuario
FACILITA_PASSWORD=sua-senha
# FACILITA_TOKEN= (Opcional se usar API de Token)

# WHATSAPP (Opcional - Usado se tiver API Oficial da Meta)
# VITE_WA_ACCESS_TOKEN=
# VITE_WA_PHONE_NUMBER_ID=
